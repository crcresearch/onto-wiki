# Find notes with a specific tag. Replace TAG_VALUE.
PREFIX llm-wiki-colab: <https://la3d.github.io/llm-wiki-colab/ontology#>
PREFIX dcterms: <http://purl.org/dc/terms/>
SELECT ?note ?title ?type WHERE {
    ?note llm-wiki-colab:tag "TAG_VALUE" .
    ?note dcterms:title ?title .
    ?note a ?type .
} ORDER BY ?title
