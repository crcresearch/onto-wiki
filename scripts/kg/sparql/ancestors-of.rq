# Walk up the hierarchy from a note to all ancestors. Replace NOTE_SLUG with the URI slug.
PREFIX llm-wiki-colab: <https://la3d.github.io/llm-wiki-colab/ontology#>
PREFIX dcterms: <http://purl.org/dc/terms/>
SELECT ?ancestor ?ancestorTitle WHERE {
    <https://la3d.github.io/llm-wiki-colab/page/NOTE_SLUG> llm-wiki-colab:up+ ?ancestor .
    ?ancestor dcterms:title ?ancestorTitle .
}
